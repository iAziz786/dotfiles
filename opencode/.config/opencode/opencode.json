{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "slack": {
      "type": "remote",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {},
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics"
      ],
      "enabled": false
    }
  }
}
